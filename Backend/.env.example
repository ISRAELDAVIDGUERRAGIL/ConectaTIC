# ============================================================
# VARIABLES DE ENTORNO - ConectaTIC v2.0.0
# ============================================================
# IMPORTANTE: Este archivo es un EJEMPLO. NO COMMITES archivos
# .env con datos sensibles a GitHub.
# En Vercel, configura las variables en el dashboard.
# ============================================================

# ============ ENTORNO ============
NODE_ENV=production
PORT=3000

# ============ BASE DE DATOS (Vercel Postgres - GRATIS) ============
# Vercel Postgres se configura automáticamente en Vercel dashboard
# NO NECESITAS HACER NADA - viene integrado con Vercel
# Solo déjalo en blanco en desarrollo (usa .env local)

# En desarrollo local (opcional, para conectarse a otra BD):
# POSTGRES_URL=postgresql://user:password@localhost:5432/conectatic

# ============ JWT (JSON Web Tokens) ============
# Crea una contraseña fuerte (mínimo 32 caracteres aleatorios)
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-characters

# Duración del token (ej: 7d, 24h, 1w)
JWT_EXPIRES_IN=7d

# ============ CORS - Orígenes permitidos ============
# Separa múltiples orígenes con comas (sin espacios)
ALLOWED_ORIGINS=https://conectatic.vercel.app,https://localhost:3000,http://localhost:3000

# ============ LOGGING ============
# DEBUG=true para más información
DEBUG=false

# ============================================================
# INSTRUCCIONES DE CONFIGURACIÓN
# ============================================================
#
# 1. VERCEL POSTGRES (GRATIS - Lo mejor para Vercel)
#    ✅ Viene incluido en Vercel (plan Free)
#    ✅ 0 configuración necesaria
#    ✅ Solo creas el proyecto en Vercel
#    ✅ Las variables de BD se crean automáticamente
#
# 2. EN DESARROLLO LOCAL
#    - Este archivo es solo template
#    - Crea Backend/.env.local con:
#      NODE_ENV=development
#      JWT_SECRET=(tu secreto)
#
# 3. EN VERCEL DASHBOARD
#    - Settings → Environment Variables
#    - Agrega:
#      NODE_ENV = production
#      JWT_SECRET = (tu secreto)
#      ALLOWED_ORIGINS = https://tu-dominio.vercel.app
#    - Vercel agrega automáticamente las variables Postgres
#
# ============================================================
