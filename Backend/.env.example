# ============================================================
# VARIABLES DE ENTORNO - ConectaTIC v2.0.0
# ============================================================
# IMPORTANTE: Este archivo es un EJEMPLO. Crea .env.production
# con los valores reales para tu entorno.
# ============================================================

# ============ ENTORNO ============
NODE_ENV=production
PORT=3000

# ============ BASE DE DATOS (MySQL - PlanetScale) ============
# Reemplaza con tu connection string de PlanetScale
DB_HOST=your-planetscale-host.mysql.databases.cloud
DB_USER=your-username
DB_PASSWORD=your-password
DB_NAME=conectatic
DB_PORT=3306

# Alternativa: usar DATABASE_URL completo
# DATABASE_URL=mysql://user:password@host:3306/database

# ============ JWT (JSON Web Tokens) ============
# Crea una contraseña fuerte (mínimo 32 caracteres aleatorios)
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-characters

# Duración del token (ej: 7d, 24h, 1w)
JWT_EXPIRES_IN=7d

# ============ CORS - Orígenes permitidos ============
# Separa múltiples orígenes con comas (sin espacios)
ALLOWED_ORIGINS=https://conectatic.vercel.app,https://localhost:3000,http://localhost:3000

# ============ LOGGING ============
# DEBUG=true para más información
DEBUG=false

# ============================================================
# INSTRUCCIONES DE CONFIGURACIÓN
# ============================================================
#
# 1. PLANETSCALE MYSQL
#    - Crea cuenta en https://planetscale.com
#    - Crea base de datos "conectatic"
#    - Copia la connection string
#    - Actualiza DB_HOST, DB_USER, DB_PASSWORD
#
# 2. JWT_SECRET
#    - Genera una contraseña aleatoria de 32+ caracteres
#    - NO uses la misma en desarrollo y producción
#
# 3. CORS
#    - Agrega TODOS los dominios del frontend
#    - Desarrollo: http://localhost:3000
#    - Producción: https://tu-frontend.vercel.app
#
# ============================================================
